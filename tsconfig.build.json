{
	"typedocOptions": {
		"entryPointStrategy": "packages",
		"entryPoints": ["packages/common", "packages/error", "packages/registry", "packages/i18n"],
		"out": "docs",
		"name": "DWS Packages",
		"hideGenerator": true,
		"customFooterHtml": "<p>Generated with ❤️</p>",
		"externalSymbolLinkMappings": {
			"@dws-std/error": {
				"Exception": "_dws_error.Exception.html"
			}
		},
		"packageOptions": {
			"includeVersion": true,
			"tsconfig": "./tsconfig.build.json"
		}
	}
}
