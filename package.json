{
	"name": "dws-packages",
	"version": "1.0.0",
	"private": true,
	"description": "DWS-Packages is a collection of packages developed by DWS for various purposes, like apis, utilities, and more.",
	"license": "MIT",
	"author": "Dominus Web Services (DWS)",
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalogs": {
			"base": {
				"@types/bun": "^1.3.10",
				"oxfmt": "^0.40.0",
				"oxlint-tsgolint": "^0.16.0",
				"oxlint": "^1.55.0",
				"typescript": "^5.9.3"
			}
		}
	},
	"type": "module",
	"scripts": {
		"clean": "find . -name 'node_modules' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name 'dist' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name 'bun.lock' -not -path '*/.git/*' -delete",
		"build": "bun --filter '!@dws-std/template' build",
		"test": "bun --filter '!@dws-std/template' test",
		"lint": "bun --filter '!@dws-std/template' lint",
		"lint:fix": "bun --filter '!@dws-std/template' lint:fix",
		"lint:github": "bun --filter '!@dws-std/template' lint:github",
		"docs": "bunx typedoc --tsconfig tsconfig.build.json"
	}
}
