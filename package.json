{
	"name": "dws-packages",
	"version": "1.0.0",
	"private": true,
	"description": "DWS-Packages is a collection of packages developed by DWS for various purposes, like apis, utilities, and more.",
	"license": "MIT",
	"author": "Dominus Web Services (DWS)",
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalogs": {
			"base": {
				"@types/bun": "^1.3.13",
				"oxfmt": "0.47.0",
				"oxlint-tsgolint": "0.22.1",
				"oxlint": "1.62.0",
				"typescript": "^6.0.3"
			}
		}
	},
	"type": "module",
	"scripts": {
		"clean": "find . -name 'node_modules' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name 'dist' -not -path '*/.git/*' -prune -exec rm -rf {} + ; find . -name 'bun.lock' -not -path '*/.git/*' -delete",
		"build": "bun --filter './packages/*' build",
		"test": "bun --filter './packages/*' test",
		"lint": "bun --filter './packages/*' lint",
		"lint:fix": "bun --filter './packages/*' lint:fix",
		"lint:github": "bun --filter './packages/*' lint:github",
		"docs": "bunx typedoc --tsconfig tsconfig.build.json"
	}
}
