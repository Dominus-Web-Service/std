{
	"name": "@dws-std/singleton-manager",
	"version": "1.0.0",
	"description": "Singleton Manager is a package that provides a simple way to manage singletons in your application. It allows you to create, retrieve, and manage singletons with ease and type safety.",
	"keywords": [
		"bun",
		"dws",
		"singleton",
		"singleton-manager",
		"type-safe"
	],
	"license": "MIT",
	"author": "Dominus Web Services (DWS)",
	"repository": {
		"type": "git",
		"url": "https://github.com/Dominus-Web-Service/packages",
		"directory": "packages/singleton-manager"
	},
	"type": "module",
	"files": ["dist"],
	"exports": {
		"./enums": {
			"types": "./dist/enums/index.d.ts",
			"default": "./dist/enums/index.js"
		},
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "bun builder.ts",
		"docs": "bunx typedoc --tsconfig tsconfig.build.json",
		"fmt:check": "oxfmt --check",
		"fmt": "oxfmt",
		"lint:fix": "oxlint --type-aware --type-check --fix ./src",
		"lint:github": "oxlint --type-aware --type-check --format=github ./src",
		"lint": "oxlint --type-aware --type-check ./src",
		"test": "bun test --pass-with-no-tests --coverage"
	},
	"dependencies": {
		"@dws-std/error": "workspace:^"
	},
	"devDependencies": {
		"@types/bun": "catalog:base",
		"oxfmt": "catalog:base",
		"oxlint-tsgolint": "catalog:base",
		"oxlint": "catalog:base",
		"typescript": "catalog:base"
	}
}
